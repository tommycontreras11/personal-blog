<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Personal Blog</h1>
    <a href="/article/new">New Post</a>
    <% if(articles.length > 0)  { %>
    <div class="posts">
        <% articles.forEach(article => { %>
            <div class="post">
                <p style="display: inline;"><%= article.title %></p>
                <p style="display: inline; margin-left: 30px;"><%= article.date %></p>
                <a href="/article/<%= article.id %>">View</a>
                <a href="/article/update/<%= article.id %>">Edit</a>
                <a href="/article/delete/<%= article.id %>">Delete</a>
            </div>
        <% }) %>
    </div>
    <% } %>
</body>
</html>