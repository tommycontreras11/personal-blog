<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>
    <link rel="stylesheet" href="/css/login-style.css">
</head>
<body>
    <div class="form">
        <form action="/sign-in" method="post">
            <h2>Sign In</h2>
            <hr>
            <div class="form-input">
                <label for="">User</label>
                <input type="text" name="user" placeholder="User" value="<%= user_input %>">
                <% if(user_error) { %>
                    <p id="user-error"><%= user_error %></p>
                <% } %>
            </div>
            <div class="form-input">
                <label for="">Password</label>
                <input type="password" name="password" placeholder="Password" value="<%= password_input %>">

                <% if(password_error) { %>
                    <p id="password-error"><%= password_error %></p>
                <% } %>
            </div>
       
            <% if(error) { %>
                <p id="form-error"><%= error %></p>
            <% } %>

            <div class="btn-submit">
                <button type="submit">Sign In</button>
            </div>
        </form>
    </div>
</body>
</html>